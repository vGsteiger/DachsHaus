# Database
DATABASE_URL=postgresql://dachshaus:dachshaus@localhost:5432/dachshaus

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Gateway
GATEWAY_PORT=4000
GATEWAY_HMAC_SECRET=your-secret-key-here

# JWT
JWT_PRIVATE_KEY_PATH=/path/to/auth-private.pem
JWT_PUBLIC_KEY_PATH=/path/to/auth-public.pem

# Auth Service
AUTH_SERVICE_URL=http://localhost:8081

# Storefront
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:4000/graphql

# GCP (for production)
GCP_PROJECT_ID=your-project-id
GCP_REGION=europe-west6
GKE_CLUSTER_NAME=dachshaus-cluster
